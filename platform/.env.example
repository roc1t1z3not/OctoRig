# OctoRig Platform — Environment Configuration
# Copy this file to .env and fill in ALL required values before starting.
#
# Generate a strong secret key:   openssl rand -hex 32
# Generate an Ed25519 key pair:   python -c "
#   from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey
#   k = Ed25519PrivateKey.generate()
#   print('private:', k.private_bytes_raw().hex())
#   print('public: ', k.public_key().public_bytes_raw().hex())"

# ── Database ────────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=              # REQUIRED — strong random password

# ── Application Security ────────────────────────────────────────────────────────
SECRET_KEY=                     # REQUIRED — min 32 chars, e.g. openssl rand -hex 32

# ── Admin Account (seeded on first start if no users exist) ────────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=                 # REQUIRED — strong password, NOT 'changeme'

# ── CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend
CORS_ORIGINS=https://your-domain.example.com

# ── Marketplace ─────────────────────────────────────────────────────────────────
# Comma-separated hex-encoded Ed25519 public keys for package signature verification.
# Leave empty to disable marketplace installation entirely.
MARKETPLACE_TRUSTED_KEYS=

# ── Debug Mode ──────────────────────────────────────────────────────────────────
# Set to true ONLY in local development — enables /docs, /redoc, verbose errors.
DEBUG=false
